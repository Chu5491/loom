{
  "name": "loom",
  "version": "0.1.0",
  "private": true,
  "description": "Slim, pass-through CLI orchestrator for multi-agent workflows.",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "bash scripts/dev.sh",
    "dev:server": "pnpm --filter @loom/server run dev",
    "dev:web": "pnpm --filter @loom/web run dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test"
  },
  "devDependencies": {
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "packageManager": "pnpm@10.21.0",
  "pnpm": {
    "onlyBuiltDependencies": ["better-sqlite3", "esbuild"]
  }
}
